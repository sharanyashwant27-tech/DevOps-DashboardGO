{
  "swagger": "2.0",
  "info": {
    "title": "DevOps Command Center API",
    "version": "1.0",
    "description": "Enterprise DevOps Dashboard REST API"
  },
  "host": "localhost:8080",
  "basePath": "/",
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header"
    }
  },
  "paths": {
    "/api/v1/auth/login": {
      "post": {
        "tags": ["auth"],
        "summary": "Login",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/v1/dashboard/stats": {
      "get": {
        "tags": ["dashboard"],
        "summary": "Dashboard statistics",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    }
  }
}
