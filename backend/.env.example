# Copy this file to .env and fill in real values for local/dev/production use.
# These env vars override config/config.yaml when set (see config/config.go).

CONFIG_PATH=config/config.yaml

# --- Server ---
SERVER_ENV=development
SERVER_PORT=8080

# --- Database (PostgreSQL) ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=devops_command_center
DATABASE_SSL_MODE=disable

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# --- Jenkins ---
JENKINS_ENABLED=false
JENKINS_BASE_URL=https://jenkins.example.com
JENKINS_USERNAME=
JENKINS_API_TOKEN=

# --- GitHub ---
GITHUB_ENABLED=false
GITHUB_TOKEN=

# --- Docker ---
DOCKER_ENABLED=false
DOCKER_HOST=unix:///var/run/docker.sock

# --- Kubernetes ---
KUBERNETES_ENABLED=false
KUBECONFIG=~/.kube/config

# --- SMTP ---
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@devops-command-center.io

# --- Slack ---
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# --- Microsoft Teams ---
TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=

# --- Logging ---
LOG_LEVEL=info
